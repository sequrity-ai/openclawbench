# OpenClawBench Configuration
# Copy this file to .env and fill in your values.
# All variables can also be set as environment variables (env vars take precedence).

# === Required for Daytona backend ===
DAYTONA_API_KEY=
DAYTONA_API_URL=https://app.daytona.io/api
DAYTONA_IMAGE=node:22-bookworm

# === Provider API keys (set the one you use) ===
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# GROQ_API_KEY=
# MISTRAL_API_KEY=
# XAI_API_KEY=
# TOGETHER_API_KEY=
# OPENROUTER_API_KEY=

# === Sequrity provider (custom) ===
# SEQURITY_API_KEY=
# SEQURITY_AZURE_KEY=
# SEQURITY_BASE_URL=https://api.sequrity.ai/control/chat/sequrity_azure/v1

# === Agent configuration ===
# AGENT_ID=main
# TIMEOUT_MULTIPLIER=1.0
# GATEWAY_PORT=18789

# === Workspace ===
# BOT_WORKSPACE_PATH=/tmp/openclaw_benchmark

# === Gmail/GOG tasks (optional) ===
# GOG_TEST_EMAIL=
# GOG_TOKEN_FILE=
# GOG_CREDENTIALS_FILE=
# GOG_KEYRING_PASSWORD=openclawbench
